---
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatDate, getAllPosts, getPostUrl } from '../lib/posts';
const posts = await getAllPosts();
const [featuredPost, ...remainingPosts] = posts;
const secondaryPosts = remainingPosts.slice(0, 3);
const archivePosts = remainingPosts.slice(3);
---

<BaseLayout>
  <section class="home-hero">
    <div class="home-hero__stripes" aria-hidden="true">
      <span></span><span></span><span></span><span></span>
    </div>
    <h1>Dean Has Something to Say</h1>
  </section>

  {
    featuredPost && (
      <section class="feature-stack" aria-labelledby="latest-post-heading">
        <h2 class="eyebrow" id="latest-post-heading">Latest</h2>

        <article class="feature-card">
          <div class="feature-card__meta">
            <span>{formatDate(featuredPost.data.date)}</span>
            {featuredPost.data.categories[0] && <span>{featuredPost.data.categories[0]}</span>}
          </div>
          <h3>
            <a href={getPostUrl(featuredPost)}>{featuredPost.data.title}</a>
          </h3>
          {featuredPost.data.description && <p>{featuredPost.data.description}</p>}
        </article>
      </section>
    )
  }

  {
    secondaryPosts.length > 0 && (
      <section class="story-grid" aria-labelledby="recent-posts-heading">
        <h2 class="eyebrow" id="recent-posts-heading">Recent</h2>

        <div class="story-grid__items">
          {secondaryPosts.map((post) => (
            <article class="story-card">
              <p class="story-card__meta">
                <span>{formatDate(post.data.date)}</span>
                {post.data.categories[0] && <span>{post.data.categories[0]}</span>}
              </p>
              <h3>
                <a href={getPostUrl(post)}>{post.data.title}</a>
              </h3>
              {post.data.description && <p>{post.data.description}</p>}
            </article>
          ))}
        </div>
      </section>
    )
  }

  <section class="archive" aria-labelledby="archive-heading">
    <h2 class="eyebrow" id="archive-heading">Archive</h2>

    <ol class="archive-list">
      {archivePosts.map((post) => (
        <li class="archive-list__item">
          <div class="archive-list__date">{formatDate(post.data.date)}</div>
          <div class="archive-list__content">
            <h3>
              <a href={getPostUrl(post)}>{post.data.title}</a>
            </h3>
            {post.data.description && <p>{post.data.description}</p>}
          </div>
        </li>
      ))}
    </ol>
  </section>
</BaseLayout>

<style is:global>
  .site-header__stripe { opacity: 0; }
</style>
