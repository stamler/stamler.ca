---
const measurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;

if (!import.meta.env.PROD || !measurementId) {
  return null;
}
---

<script is:inline define:vars={{ measurementId }}>
  const doNotTrackEnabled =
    window.doNotTrack === '1' ||
    navigator.doNotTrack === '1' ||
    navigator.doNotTrack === 'yes' ||
    navigator.msDoNotTrack === '1';

  window['ga-disable-' + measurementId] = doNotTrackEnabled;

  if (!doNotTrackEnabled) {
    const script = document.createElement('script');
    script.async = true;
    script.src = `https://www.googletagmanager.com/gtag/js?id=${measurementId}`;
    document.head.appendChild(script);

    window.dataLayer = window.dataLayer || [];
    window.gtag = function gtag() {
      window.dataLayer.push(arguments);
    };

    window.gtag('js', new Date());
    window.gtag('config', measurementId);
  }
</script>
