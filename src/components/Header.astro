---
import { navigation, siteConfig } from '../lib/site';

const { pathname } = Astro.url;
---

<header class="site-header">
  <div class="site-header__stripe" aria-hidden="true"></div>
  <div class="site-header__inner">
    <a class="site-brand" href="/">{siteConfig.title}</a>

    <nav class="site-nav" aria-label="Primary">
      {
        navigation.map((item) => {
          const isCurrent =
            item.href === '/'
              ? pathname === '/'
              : pathname.startsWith(item.href);

          return (
            <a class:list={['site-nav__link', isCurrent && 'is-current']} href={item.href}>
              {item.label}
            </a>
          );
        })
      }
    </nav>
  </div>
</header>
